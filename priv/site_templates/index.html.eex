<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cinder UI - Phoenix + LiveView Component Library</title>
    <meta
      name="description"
      content="Production-ready Phoenix + LiveView components with shadcn-inspired design, typed HEEx APIs, and one-command installer for existing apps."
    />
    <%= theme_bootstrap_script %>
    <link rel="stylesheet" href="<%= theme_css_path %>" />
    <link rel="stylesheet" href="<%= site_css_path %>" />
    <script type="application/speculationrules">
      {
        "prefetch": [
          {
            "source": "document",
            "where": {
              "href_matches": "/docs/*"
            },
            "eagerness": "eager"
          }
        ]
      }
    </script>
  </head>
  <body class="bg-background text-foreground">
    <header class="sticky top-0 z-50 border-b bg-background/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-[1200px] flex-wrap items-center justify-between gap-3 px-4 py-4 md:px-6">
        <a href="./" class="text-2xl font-black tracking-tight">Cinder UI</a>
        <%= header_controls_html %>
      </div>
    </header>

    <main>
      <%= hero_html %>

      <div class="home-section-divider">
        <div class="home-section-dot"></div>
      </div>

      <%= component_examples_html %>

      <div class="home-section-divider">
        <div class="home-section-dot"></div>
      </div>

      <%= install_html %>

      <div class="home-section-divider">
        <div class="home-section-dot"></div>
      </div>

      <%= features_html %>
    </main>

    <footer class="border-t bg-card/50">
      <div class="mx-auto max-w-[1200px] px-4 py-16 md:px-6">
        <div class="space-y-6 text-center">
          <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Ready to build?</h2>
          <p class="mx-auto max-w-md text-muted-foreground">
            Start using production-ready components in your Phoenix app today.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <%= footer_cta_html %>
          </div>
        </div>
        <div class="mt-16 border-t pt-8 text-center text-sm text-muted-foreground">
          <p>
            Cinder UI is an independent project based on the design and API patterns of
            <a href="<%= shadcn_url %>" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4">shadcn/ui</a>, built for Elixir, Phoenix, and LiveView by
            <a href="https://levibuzolic.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4">Levi Buzolic</a>.
          </p>
        </div>
      </div>
    </footer>

    <script type="module" src="<%= theme_script_src %>"></script>
  </body>
</html>
