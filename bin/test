#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEMO_DIR="${ROOT_DIR}/demo"

if ! command -v mise >/dev/null 2>&1; then
	echo "error: required command 'mise' is not installed or not on PATH" >&2
	exit 1
fi

echo "---------- Root unit tests"
MIX_ENV="test" exec mise exec -- mix coveralls.cobertura --raise

cd "$DEMO_DIR"
echo "---------- Demo unit tests"
exec mise exec -- mix test
echo "---------- Demo JS tests"
exec mise exec -- vitest run
echo "---------- Demo Playwright tests"
exec mise exec -- npx playwright test
