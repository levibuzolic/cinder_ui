#!/usr/bin/env node

const fs = require("fs")
const path = require("path")

const root = path.resolve(__dirname, "..")
const sourceRoot = path.join(root, "priv", "templates", "cinder_ui")
const outputPath = path.join(root, "priv", "templates", "cinder_ui.js")

const sources = [
  "constants.js",
  "dom.js",
  "commands.js",
  "focus.js",
  "inert.js",
  "hooks/dialog.js",
  "hooks/panels.js",
  "hooks/popover.js",
  "hooks/dropdown_menu.js",
  "hooks/menubar.js",
  "hooks/select.js",
  "hooks/autocomplete.js",
  "hooks/input_otp.js",
  "hooks/code_block.js",
  "hooks/combobox.js",
  "hooks/sidebar.js",
  "hooks/carousel.js",
  "hooks/resizable.js",
  "index.js",
]

const stripImports = (content) =>
  content
    .split("\n")
    .filter((line) => !line.startsWith("import "))
    .join("\n")

const removeInternalExports = (content) =>
  content.replace(/^export const (?!CinderUIHooks\b|CinderUI\b)/gm, "const ")

const build = () => {
  const body = sources
    .map((source) => {
      const absolutePath = path.join(sourceRoot, source)
      const content = fs.readFileSync(absolutePath, "utf8").trimEnd()
      return removeInternalExports(stripImports(content))
    })
    .join("\n\n")

  return `// This file is generated by bin/build-cinder-ui-js from priv/templates/cinder_ui/.\n// Do not edit it directly; edit the modular sources instead.\n\n${body}\n`
}

const output = build()

if (process.argv.includes("--check")) {
  const existing = fs.readFileSync(outputPath, "utf8")
  if (existing !== output) {
    console.error("priv/templates/cinder_ui.js is out of date. Run bin/build-cinder-ui-js.")
    process.exit(1)
  }
  process.exit(0)
}

fs.writeFileSync(outputPath, output)
